{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^@app/database(|/.*)$": "<rootDir>/../libs/database/src/$1",
    "^@app/file-upload(|/.*)$": "<rootDir>/../libs/file-upload/src/$1",
    "^@app/swagger(|/.*)$": "<rootDir>/../libs/swagger/src/$1"
  }
}